@page "/admin/login"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpContextAccessor
@inject IConfiguration Config
@using Microsoft.AspNetCore.RateLimiting
@attribute [EnableRateLimiting("AuthLimit")]
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-header bg-dark text-white">Admin Login</div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }
                    <div class="mb-3">
                        <label>ID</label>
                        <input type="text" class="form-control" @bind="username" />
                    </div>
                    <div class="mb-3">
                        <label>Password</label>
                        <input type="password" class="form-control" @bind="password" />
                    </div>
                    <button class="btn btn-primary w-100" @onclick="HandleLogin">Login</button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string username = "";
    private string password = "";
    private string? errorMessage;

    private async Task HandleLogin()
    {
        // .env や appsettings.json から値を取得
        var adminId = Config["ADMIN_ID"];
        var adminPass = Config["ADMIN_PASSWORD"];
        // ここに固定のID/パスワードを設定（実際は環境変数等から取得を推奨）
        if (username == adminId && password == adminPass)
        {
            var claims = new List<Claim> { new Claim(ClaimTypes.Name, "Admin") };
            var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
            var principal = new ClaimsPrincipal(identity);

            // Note: Blazor ServerでのログインはHttpContextの直接操作が必要なため、
            // 実際には Login 専用のコントローラーへ POST するか、
            // HttpContextAccessor を経由してサインインします。
            await HttpContextAccessor.HttpContext!.SignInAsync(principal);
            Nav.NavigateTo("/admin", true);
        }
        else
        {
            errorMessage = "Invalid credentials.";
        }
    }
}